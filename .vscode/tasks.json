{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Current Java file",
            "type": "shell",
            "command": "java",
            "args": [
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
